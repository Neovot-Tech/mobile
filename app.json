{
  "expo": {
    "name": "Neovot",
    "slug": "neovot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-mini-red.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.neovot.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.neovot.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-mini-red.png",
        "backgroundColor": "#FFFFFF"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/logo-mini-red.png",
      "name": "Neovot",
      "shortName": "Neovot",
      "description": "Your AI health companion — health monitoring and daily summaries for elderly Ghanaians and their caregivers.",
      "themeColor": "#003B46",
      "backgroundColor": "#003B46",
      "display": "standalone",
      "orientation": "portrait",
      "lang": "en",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Neovot to access your microphone so you can speak your health updates."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Neovot to use your camera to capture a photo of a device reading or a prescription.",
          "photosPermission": "Allow Neovot to access your photos so you can upload an image of a device reading or a prescription."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#003B46",
          "image": "./assets/logo-mini-white.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "6ab27a39-0452-4037-8f27-b23a7bbe3da5"
      }
    }
  }
}
